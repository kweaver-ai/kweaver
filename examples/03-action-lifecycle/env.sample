# Database connection (MySQL)
# MYSQL_BIN=/opt/homebrew/opt/mysql-client/bin/mysql

# Host for kweaver ds connect — reachable from K8s pods (internal IP).
DB_HOST=192.168.40.105
# Optional: host for Step 0 only (mysql on your laptop).
# DB_HOST_SEED=203.0.113.10
DB_PORT=3306
# Must already exist. User needs CREATE/DROP/INSERT.
DB_NAME=supply_chain
DB_USER=root
DB_PASS=changeme

# Set to 1 or true for extra diagnostics (passwords never printed).
# DEBUG=1
